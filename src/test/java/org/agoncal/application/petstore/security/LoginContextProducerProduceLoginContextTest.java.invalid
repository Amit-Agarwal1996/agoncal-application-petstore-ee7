package org.agoncal.application.petstore.security;import org.junit.experimental.categories.Category;
import org.agoncal.application.petstore.util.ConfigProperty;
import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api.Test;
import javax.security.auth.login.LoginContext;
import javax.security.auth.login.LoginException;
import java.net.URISyntaxException;
import javax.enterprise.inject.Produces;
import javax.inject.Inject;
import java.io.File;

public class LoginContextProducerProduceLoginContextTest {
    @Inject
    private SimpleCallbackHandler callbackHandler;
    
    @Test
    public void produceLoginContext_withValidConfig_canCreateLoginContext() throws LoginException, URISyntaxException {
        LoginContext loginContext = new LoginContextProducer().produceLoginContext("validConfigFile", "validModuleName");
        Assertions.assertNotNull(loginContext);
    }
    @Test
    public void produceLoginContext_withInvalidConfig_throwsLoginException() throws URISyntaxException {
        Assertions.assertThrows(LoginException.class, () ->
                new LoginContextProducer().produceLoginContext("invalidConfigFile", "validModuleName")
        );
    }
}